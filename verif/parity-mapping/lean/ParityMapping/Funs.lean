        let cf ← core.result.Result.Insts.CoreOpsTry.branch r
        match cf with
        | core.ops.control_flow.ControlFlow.Continue val =>
          let o ← lift (U64.checked_mul addr.neighborhood val)
          match o with
          | none =>
            ok (core.result.Result.Err MappingError.DataOrdinalOverflow)
