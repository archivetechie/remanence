  then ok (core.result.Result.Err MappingError.StripeIndexOutsideScheme)
  else
    match addr.position with
    | StripePosition.Data index =>
      if index >= scheme.data_blocks_per_stripe
      then ok (core.result.Result.Err MappingError.DataIndexOutsideScheme)
