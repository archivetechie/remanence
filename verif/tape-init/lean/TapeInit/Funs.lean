/-- [tape_init_verif::decide_ours_init]:
    Source: 'src/lib.rs', lines 162:0-222:1
    Visibility: public -/
def decide_ours_init
  (bot_uuid : Std.U64) (bot_geometry : TapeInitGeometry)
  (catalog_row : Option CatalogTapeInitRow)
  (barcode_state : BarcodeLifecycleState) (physical_data_past_bootstrap : Bool)
  (committed_copies : CommittedCopyState) :
  Result InitDecision
  := do
  match barcode_state with
  | BarcodeLifecycleState.Available =>
    match catalog_row with
    | none =>
      ok (InitDecision.NeedsExplicitRebuild TapeInitError.MissingCatalogRow)
    | some row =>
      if row.uuid != bot_uuid
      then ok (InitDecision.Anomaly TapeInitError.MediaSwapReusedBarcode)
      else
        let b ← disposition_is_retired row.disposition
        if b
        then ok InitDecision.FreshInit
        else
          let b1 ← relation_is_unrecorded_relabel row.barcode_relation
          if b1
          then
            ok (InitDecision.Anomaly
              TapeInitError.BarcodeChangedWithoutRelabel)
          else
            if physical_data_past_bootstrap
            then refuse TapeInitError.PhysicalDataPastBootstrap
            else
              let b2 ←
                CommittedCopyState.has_committed_copies committed_copies
              if b2
              then refuse TapeInitError.CommittedCopiesPresent
              else
                let b3 ← geometry_matches bot_geometry row.geometry
                if b3
                then
                  if row.catalog_unwritten
                  then ok InitDecision.IdempotentNoOp
                  else refuse TapeInitError.CatalogIndicatesWritten
                else
                  ok (InitDecision.RequireForce TapeInitError.GeometryMismatch)
  | BarcodeLifecycleState.AssignedTo assigned_uuid =>
    if assigned_uuid = bot_uuid
    then
      match catalog_row with
      | none =>
        ok (InitDecision.NeedsExplicitRebuild TapeInitError.MissingCatalogRow)
      | some row =>
        if row.uuid != bot_uuid
        then ok (InitDecision.Anomaly TapeInitError.MediaSwapReusedBarcode)
        else
          let b ← disposition_is_retired row.disposition
          if b
          then ok InitDecision.FreshInit
          else
            let b1 ← relation_is_unrecorded_relabel row.barcode_relation
            if b1
            then
              ok (InitDecision.Anomaly
                TapeInitError.BarcodeChangedWithoutRelabel)
            else
              if physical_data_past_bootstrap
              then refuse TapeInitError.PhysicalDataPastBootstrap
              else
                let b2 ←
                  CommittedCopyState.has_committed_copies committed_copies
                if b2
                then refuse TapeInitError.CommittedCopiesPresent
                else
                  let b3 ← geometry_matches bot_geometry row.geometry
                  if b3
                  then
                    if row.catalog_unwritten
                    then ok InitDecision.IdempotentNoOp
                    else refuse TapeInitError.CatalogIndicatesWritten
                  else
                    ok (InitDecision.RequireForce
                      TapeInitError.GeometryMismatch)
    else ok (InitDecision.Anomaly TapeInitError.BarcodeAssignedToDifferentUuid)
  | BarcodeLifecycleState.Retired =>
    ok (InitDecision.Anomaly TapeInitError.BarcodeRetired)

/-- [tape_init_verif::decide_blank_init]:
    Source: 'src/lib.rs', lines 139:0-160:1
    Visibility: public -/
def decide_blank_init
  (barcode_state : BarcodeLifecycleState)
  (committed_copies : CommittedCopyState) :
  Result InitDecision
  := do
  match barcode_state with
  | BarcodeLifecycleState.Available =>
    let b ← CommittedCopyState.has_committed_copies committed_copies
    if b
    then refuse TapeInitError.CommittedCopiesPresent
    else ok InitDecision.FreshInit
  | BarcodeLifecycleState.AssignedTo _ =>
    ok (InitDecision.Anomaly TapeInitError.BarcodeAssignedToDifferentUuid)
  | BarcodeLifecycleState.Retired =>
    ok (InitDecision.Anomaly TapeInitError.BarcodeRetired)

/-- [tape_init_verif::decide_tape_init]:
    Source: 'src/lib.rs', lines 112:0-137:1
    Visibility: public -/
def decide_tape_init
  (bot : BotClassification) (catalog_row : Option CatalogTapeInitRow)
  (barcode_state : BarcodeLifecycleState) (physical_data_past_bootstrap : Bool)
  (committed_copies : CommittedCopyState) :
  Result InitDecision
  := do
  let o ← committed_pool_conflict committed_copies
  match o with
  | none =>
    match bot with
    | BotClassification.BlankCheckEod =>
      decide_blank_init barcode_state committed_copies
    | BotClassification.OursBootstrap uuid geometry =>
      decide_ours_init uuid geometry catalog_row barcode_state
        physical_data_past_bootstrap committed_copies
    | BotClassification.ForeignFormat => refuse TapeInitError.ForeignFormat
    | BotClassification.ReadError => refuse TapeInitError.BotReadError
    | BotClassification.UnrecognizedData =>
      refuse TapeInitError.UnrecognizedData
  | some reason => ok (InitDecision.Anomaly reason)

